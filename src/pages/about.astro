---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Claudia | Portfolio',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Portfolio"
    image={{
      // Optional: replace later with a headshot or remove image by setting it to null if supported
      src: 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=2070&q=80',
      alt: 'Workspace',
    }}
  >
    <Fragment slot="title">
      Hi, I’m <span class="text-accent dark:text-white">Claudia</span>.<br />
      Computer Science student & software developer.
    </Fragment>

    <Fragment slot="subtitle">
      I build full-stack applications with Python, Flask, JavaScript, and modern UI tooling.
      I’m currently developing <strong>CoAdapt</strong> — a project management platform with task tracking,
      financial tracking, and timesheet-based cost calculations.
    </Fragment>

    <Fragment slot="actions">
      <div class="flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/blog">View Course Project Blog</a>
        <a class="btn btn-secondary" href="/resume.pdf" target="_blank" rel="noopener">Download Resume</a>
        <a class="btn btn-tertiary" href="#contact">Contact</a>
      </div>
    </Fragment>
  </Hero>

  