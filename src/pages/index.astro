---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'AstroWind — Free template for creating websites with Astro + Tailwind CSS',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={{ title: 'Claudia | Portfolio', ignoreTitleTemplate: true }}>
  
  <!-- HERO -->
  <Hero
    actions={[
      { variant: 'primary', text: 'Weekly Project Blog', href: '/blog' },
      { text: 'Download Resume', href: '/resume.pdf' },
    ]}
  >
    <Fragment slot="title">
      <span class="text-accent dark:text-white">Claudia Vargas</span>
      <br />
      Full-Stack Engineer
      <br />
    </Fragment>

    <Fragment slot="subtitle">
      Creative problem-solver and full-stack developer specializing in API design
      and Core/UI engineering using Python, Flask, and C#.
    </Fragment>
  </Hero>

  <!-- SKILLS -->
  <section id="skills" class="mx-auto max-w-5xl px-4 py-16">
    <h2 class="text-3xl font-bold">Technical Skills</h2>

    <div class="mt-6 space-y-6">

      <div>
        <h3 class="font-semibold">Backend & APIs</h3>
        <p>Python, C#, REST, API integrations, database design</p>
      </div>

      <div>
        <h3 class="font-semibold">Frontend & UI</h3>
        <p>Core/UI engineering, JavaScript, CSS</p>
      </div>

      <div>
        <h3 class="font-semibold">DevOps & Infrastructure</h3>
        <p>AWS EC2, Jenkins CI, installer release validation</p>
      </div>

      <div>
        <h3 class="font-semibold">Business Systems & Tools</h3>
        <p>Salesforce, Celoxis, Jira</p>
      </div>

      <div>
        <h3 class="font-semibold">Tools</h3>
        <p>GitHub, Git Bash, Jupyter, VSCode, Visual Studio, Linux</p>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="mx-auto max-w-5xl px-4 py-16">
  <h2 class="text-3xl font-bold">Professional Experience</h2>

  <div class="mt-8">
    <h3 class="text-xl font-semibold">Software Developer I — EMA3D (2025–Present)</h3>
    <ul class="mt-4 space-y-2">
      <li>• Transitioned from Project Manager to full-time Software Developer while training two successors.</li>
      <li>• Built the first API integration between Celoxis and QBTime, saving $20K upfront and $5K annually.</li>
      <li>• Improved CI stability by monitoring and resolving Jenkins build failures.</li>
      <li>• Worked with AWS EC2 release candidates for installer validation and deployment testing.</li>
      <li>• Contributed to core/UI engineering for CAD-based simulation systems (Ansys integrations).</li>
      <li>• Increased unit test coverage across Python and C# codebases.</li>
    </ul>
  </div>

  <div class="mt-8">
    <h3 class="text-xl font-semibold">Project Manager — EMA3D</h3>
    <ul class="mt-4 space-y-2">
      <li>• Revamped project operations, scaling active projects from 20–30 to 50–75 ($15M+ portfolio).</li>
      <li>• Implemented Celoxis company-wide as project management infrastructure.</li>
      <li>• Led workflow automation and reporting through Salesforce.</li>
      <li>• Drove record profitability through operational efficiency improvements.</li>
    </ul>
  </div>
</section>

  <!-- EDUCATION -->
  <section id="education" class="mx-auto max-w-5xl px-4 py-16">
    <h2 class="text-3xl font-bold">Education</h2>
    <p class="mt-4 text-lg font-semibold">B.S. Computer Science</p>
    <p>Expected Graduation: 2026</p>
    <p class="mt-2">Focused on machine learning/ AI coursework.</p>

    <p class="mt-4 text-lg font-semibold">B.S. Business Marketing</p>
    <p>Graduation: 2020</p>
  </section>

  <!-- BLOG PREVIEW -->
  <BlogLatestPosts
    title="Course Project Blog"
    information="Follow my development progress as I build new features."
  />

  <!-- CONTACT -->
  <section id="contact" class="mx-auto max-w-5xl px-4 py-16">
    <h2 class="text-3xl font-bold">Contact</h2>
    <p class="mt-4">
      Email:
      <a class="underline" href="mailto:clva4454@colorado.edu">
        clva4454@colorado.edu
      </a>
    </p>
    <p class="mt-2">
      LinkedIn:
      <a class="underline" href="https://www.linkedin.com/in/claudia-vargas-b80065137/">
        linkedin.com/in/claudia-vargas
      </a>
    </p>
    <p class="mt-2">
      GitHub:
      <a class="underline" href="https://github.com/Dan1731">
        github.com/Dan1731
      </a>
    </p>
  </section>

</Layout>